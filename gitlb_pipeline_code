docker_build_push:
stage: docker
script:
- mvn clean package (This creates a JAR file inside the target/ directory like target/app.jar)
- docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD
- docker build -t savita/boardgamegitlab:v1 .
- docker push savita/boardgamegitlab:v1 
tags:
- self-hosted
only:
- main
k8s_deploy:
stage: deploy
variables:
- KUBECONFIG_PATH: /home/ubuntu/.kube/config
before_script:
- mkdir -p $(dirname "KUBECONFIG_PATH")
- echo "$KUECONFIG_CONTENT" | base64 -d > "$KUBECONFIG_PATH"
- export KUBECONFIG="$KUBECONFIG_PATH"
script:
- k apply -f devlopment-service.yaml
tags:
- self-hosted
only:
- main



